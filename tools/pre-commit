#!/usr/bin/env bash
# spec-lint pre-commit hook — blocks the commit when spec-lint FAILs.
# Install: bash tools/setup-hooks.sh
set -euo pipefail

# Only run when spec files are staged.
git diff --cached --name-only | grep -qE '^(specs|\.spec)/' || exit 0

PYTHON="$(command -v python3 || command -v python || true)"
if [ -z "$PYTHON" ]; then
  echo "spec-lint: python not found — skipping (install Python 3 to enable)"
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
[ -f "$ROOT/tools/spec-lint.py" ] || exit 0

# Lint the STAGED snapshot, not the working tree — otherwise staged-bad /
# worktree-fixed commits slip through (and clean commits get blocked by
# unstaged breakage). checkout-index materializes exactly what will commit.
STAGE_DIR="$(mktemp -d)"
trap 'rm -rf "$STAGE_DIR"' EXIT
git checkout-index -a --prefix="$STAGE_DIR/"

echo "spec-lint: checking staged specs..."
if ! "$PYTHON" "$ROOT/tools/spec-lint.py" --no-color --root "$STAGE_DIR"; then
  echo ""
  echo "spec-lint: FAILED — fix the errors above before committing."
  echo "  To skip (not recommended): git commit --no-verify"
  exit 1
fi
